---
import type { CourseModule } from "@/data/course";
import MobileDrawerTrigger from "@/components/MobileDrawerTrigger.astro";
import PageHeader from "@/components/PageHeader.astro";
import WebModuleSection from "@/components/web/WebModuleSection.astro";
import { courseTotalSeconds, fmtMinDuration } from "@/lib/progress";

interface Props {
  course: CourseModule[];
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { course, eyebrow, title, subtitle } = Astro.props;

const totalLessons = course.reduce(
  (sum, mod) => sum + mod.chapters.reduce((s, ch) => s + ch.lessons.length, 0),
  0,
);
const totalSec = courseTotalSeconds(course);
---

<main
  id="mainPane"
  tabindex="-1"
  class="min-h-screen overflow-y-auto px-4 py-6 md:px-6 md:py-8 lg:px-8 lg:py-10"
>
  <div class="md:hidden mb-4">
    <MobileDrawerTrigger />
  </div>

  <div class="mx-auto max-w-content">
    <a href="../" class="mb-4 inline-flex items-center gap-1 text-tiny text-fg-muted transition-colors hover:text-fg-default">
      <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
      Dashboard
    </a>

    <PageHeader
      eyebrow={eyebrow}
      eyebrowRight={`0 / ${totalLessons}`}
      title={title}
      subtitle={subtitle}
    >
      <Fragment slot="below-title">
        <div class="mt-5 grid gap-2">
          <div class="h-2.5 overflow-hidden rounded-full bg-surface-2">
            <div
              id="webOverallBar"
              class="h-full rounded-full bg-accent transition-[width] duration-300"
              style="width: 0%"
            ></div>
          </div>
          {totalSec > 0 && (
            <div class="flex items-baseline gap-1 font-mono text-tiny text-fg-muted">
              <span id="webWatchedTime">0m</span>
              <span class="text-fg-subtle">/</span>
              <span>{fmtMinDuration(totalSec)}</span>
              <span class="ml-1 text-fg-subtle">watched</span>
            </div>
          )}
        </div>
      </Fragment>
    </PageHeader>

    <div class="mt-6 rounded-lg border border-default bg-surface p-4">
      {course.map((module) => <WebModuleSection module={module} />)}
    </div>
  </div>
</main>
