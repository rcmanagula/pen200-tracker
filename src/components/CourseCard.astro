---
import type { Course } from "@/data/courses";

interface Props {
  course: Course;
  base: string;
}

const { course, base } = Astro.props;
const cleanBase = base.endsWith("/") ? base : `${base}/`;
const href = `${cleanBase}${course.href}`;
---

<article
  class="flex min-h-[18rem] flex-col gap-4 rounded-lg border border-default bg-surface p-5 shadow-card"
  data-course-card={course.id}
>
  <div class="flex items-start justify-between gap-3">
    <span
      aria-hidden="true"
      class="inline-flex h-11 w-11 items-center justify-center rounded-md bg-accent text-small font-bold text-on-accent"
    >{course.icon}</span>
    <span
      class="rounded-md border border-default px-2.5 py-1 font-mono text-tiny text-fg-muted"
      data-course-percent={course.id}
    >-</span>
  </div>

  <div>
    <h2 class="font-display text-h2 text-fg-default">{course.shortName}</h2>
    <p class="mt-1 text-small font-semibold text-fg-default">{course.name}</p>
    <p class="mt-2 text-small text-fg-muted">{course.description}</p>
  </div>

  <div class="mt-auto grid gap-2">
    <div class="h-2 w-full overflow-hidden rounded-full bg-surface-2">
      <div
        class="h-full rounded-full bg-accent transition-[width] duration-300"
        style="width: 0%"
        data-course-bar={course.id}
      ></div>
    </div>
    <div class="flex items-center justify-between gap-3 text-tiny text-fg-muted">
      <span data-course-done={course.id}>0 / {course.totalItems}</span>
      <span data-course-last={course.id}>No activity</span>
    </div>
  </div>

  <a href={href} class="btn btn-primary self-start">Continue</a>
</article>
